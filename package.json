{
  "name": "@dynodesign/components",
  "version": "0.1.5",
  "description": "DynoDesign adaptive component library — token-driven React components with customizable CSS theming",
  "author": "Lise Noble",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public/styles",
    "docs",
    ".cursorrules",
    "CLAUDE.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./provider": {
      "import": "./dist/DynoDesignProvider.esm.js",
      "require": "./dist/DynoDesignProvider.js"
    },
    "./public/styles/foundations.css": "./public/styles/foundations.css",
    "./public/styles/core.css": "./public/styles/core.css",
    "./public/styles/Light-Mode.css": "./public/styles/Light-Mode.css",
    "./public/styles/Dark-Mode.css": "./public/styles/Dark-Mode.css",
    "./public/styles/base.css": "./public/styles/base.css",
    "./public/styles/styles.css": "./public/styles/styles.css"
  },
  "scripts": {
    "start": "react-scripts start",
    "build:app": "react-scripts build",
    "build:lib": "rollup -c rollup.config.js",
    "build": "npm run build:lib",
    "test": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:a11y": "react-scripts test --testPathPattern=test --watchAll=false",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy-storybook": "storybook-to-ghpages",
    "prepublishOnly": "npm run build:lib",
    "predeploy": "npm run build:app",
    "deploy": "gh-pages -d build"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0",
    "@mui/icons-material": ">=5.0.0",
    "@mui/material": ">=5.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/preset-create-react-app": "^8.6.18",
    "@storybook/react": "^8.0.0",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/storybook-deployer": "^2.8.16",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "babel-loader": "^10.1.1",
    "gh-pages": "^6.3.0",
    "jest-axe": "^8.0.0",
    "prop-types": "^15.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "storybook": "^8.6.18",
    "webpack": "^5.105.4"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "tokens",
    "theming",
    "accessibility",
    "dynodesign"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/skyler-h-noble/DinoDesign"
  },
  "dependencies": {
    "eslint-plugin-react-hooks": "^7.0.1",
    "react-router-dom": "^7.13.1",
    "react-scripts": "^5.0.1"
  },
  "homepage": "/",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
